# Backend API
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false
API_AUTH_TOKEN=
JOB_RETENTION_SECONDS=86400
JOB_MAX_HISTORY=2000
WEBHOOK_NOTIFY_URL=
WEBHOOK_NOTIFY_TOKEN=
WEBHOOK_NOTIFY_TIMEOUT_SECONDS=3
WEBHOOK_NOTIFY_MIN_SCORE=75

# Detection tuning
WINDOW_SIZE_MINUTES=5
BRUTE_FORCE_THRESHOLD=10
BRUTE_FORCE_WINDOW=5
STUFFING_FAIL_THRESHOLD=5
SCAN_ENDPOINT_THRESHOLD=40
SCAN_RATE_THRESHOLD=20.0
IF_CONTAMINATION=0.05

# Optional data-path overrides
DBIP_COUNTRY_PATH=data/dbip-country-lite.csv
GEOIP_OVERRIDE_PATH=data/geoip_overrides.json
KNOWN_BAD_PATH=data/known_bad_ips.csv
SCAN_RESULTS_DIR=data/scan_results
